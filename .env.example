# ── Copy this file to .env and fill in the values ─────────────────────────
# cp .env.example .env

# Admin panel password (used by the frontend admin page and backend JWT auth)
ADMIN_PASSWORD=990115

# JWT signing secret — CHANGE THIS to a random string in production!
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# JWT token lifetime (hours)
JWT_TTL_HOURS=12

# Port exposed on the host machine
HTTP_PORT=80

# Log level: debug | info | warning | error
LOG_LEVEL=info
